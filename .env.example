# =========================================================
# Conexão com o Supabase — preencha com os dados do SEU projeto
# =========================================================
# Como obter:
# 1. Acesse https://supabase.com e abra seu projeto
# 2. Vá em: Project Settings → API
# 3. Copie "Project URL" e "anon public key"
#
# Passos:
# 1. Copie este arquivo e renomeie para ".env"  (sem .example)
# 2. Cole os valores abaixo
# 3. Rode novamente:  npm run dev
#
# IMPORTANTE: nunca suba o .env para o GitHub (já está no .gitignore).
# ---------------------------------------------------------

VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="cole_aqui_a_anon_public_key"
VITE_SUPABASE_PROJECT_ID="seu-projeto-id"

# Variáveis equivalentes para uso no servidor (SSR). Use os MESMOS valores.
SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_PUBLISHABLE_KEY="cole_aqui_a_anon_public_key"
